@{
    ViewData["Title"] = "Proteger PDF";
}

<link rel="stylesheet" href="~/lib/bootstrap/font/bootstrap-icons.css" />

<div id="loader-overlay" style="display:none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(255,255,255,0.8); z-index: 9999; justify-content: center; align-items: center; flex-direction: column;">
    <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;"></div>
    <h3 id="loader-text" class="mt-3">Cifrando documento...</h3>
    <p>Aplicando seguridad al archivo PDF.</p>
</div>

<div class="container mt-5">
    <div class="main-content-card shadow-lg p-4 bg-white rounded mx-auto" style="max-width: 600px;">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary btn-sm"> ← Volver</a>
            <h2 class="fw-bold m-0 text-primary"><i class="bi bi-shield-lock"></i> Proteger PDF</h2>
        </div>

        <p class="text-muted">Asigna una contraseña de apertura para proteger la privacidad del documento.</p>

        <form asp-action="Procesar" method="post" enctype="multipart/form-data" id="formProteger" class="mt-4">
            <div class="mb-4 text-start">
                <label class="form-label fw-bold">1. Selecciona el archivo:</label>
                <input type="file" name="archivo" class="form-control form-control-lg" accept=".pdf" required />
            </div>

            <div class="mb-4 text-start">
                <label class="form-label fw-bold">2. Define la contraseña:</label>
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-key-fill"></i></span>
                    <input type="password" name="clave" id="claveInput" class="form-control form-control-lg" placeholder="Escribe la clave aquí" required />
                    <button class="btn btn-outline-secondary" type="button" id="btnToggle" onclick="togglePassword()"><i class="bi bi-eye"></i></button>
                </div>
            </div>


            <button type="submit" id="btnSubmitProteger" class="btn btn-primary btn-lg w-100 shadow fw-bold">
                Cifrar y Descargar PDF
            </button>
        </form>
    </div>
</div>

<div class="modal fade" id="passwordModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-body text-center p-5">
                <i class="bi bi-shield-lock text-warning" style="font-size: 3rem;"></i>
                <h4 class="fw-bold mt-3">Documento Protegido</h4>
                <p class="text-muted">Este archivo requiere una contraseña para abrirse.</p>

                <div id="errorPassword" class="alert alert-danger py-1 small" style="display:none;">Contraseña incorrecta</div>

                <div class="input-group mb-3 mt-4">
                    <input type="password" id="pdfPass" class="form-control form-control-lg" placeholder="Ingresa la clave">
                    <button class="btn btn-primary px-4" onclick="probarClave()">Desbloquear</button>
                </div>
                <button type="button" class="btn btn-link btn-sm text-muted" onclick="location.reload()">Cancelar y subir otro</button>
            </div>
        </div>
    </div>
</div>

<style>
    .main-content-card {
        border-top: 5px solid #0d6efd; /* Color primario para consistencia */
    }

    .input-group-text {
        border-right: none;
    }

    #claveInput {
        border-left: none;
    }

        #claveInput:focus {
            border-color: #dee2e6;
            box-shadow: none;
        }
</style>

@section Scripts {
    <script>
        function togglePassword() {
            const input = document.getElementById('claveInput');
            const icon = document.querySelector('#btnToggle i');
            if (input.type === "password") {
                input.type = "text";
                icon.classList.replace('bi-eye', 'bi-eye-slash');
            } else {
                input.type = "password";
                icon.classList.replace('bi-eye-slash', 'bi-eye');
            }
        }

        // CONTROL DEL LOADER Y BLOQUEO DE BOTONES
        document.getElementById('formProteger').onsubmit = function() {
            const btn = document.getElementById('btnSubmitProteger');
            const overlay = document.getElementById('loader-overlay');

            // Bloqueo visual
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Procesando...';
            if(overlay) overlay.style.display = 'flex';

            // Apagar overlay tras 3 segundos (tiempo estimado de respuesta y descarga)
            setTimeout(() => {
                if(overlay) overlay.style.display = 'none';
                btn.disabled = false;
                btn.innerHTML = 'Cifrar y Descargar PDF';
            }, 3000);
        };
        function togglePassword() {
            const input = document.getElementById('claveInput');
            const icon = document.querySelector('#btnToggle i');

            if (input.type === "password") {
                input.type = "text";
                icon.className = "bi bi-eye-slash";
            } else {
                input.type = "password";
                icon.className = "bi bi-eye";
            }
        }

    </script>
}