<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>DynaPDF</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div id="loader-overlay">
        <div class="spinner mb-3"></div>
        <h3 class="fw-bold">Procesando...</h3>
        <p>DynaPDF está transformando su archivo.</p>
    </div>

    <header>
        <nav class="navbar navbar-light bg-white border-bottom shadow-sm">
            <div class="container d-flex justify-content-center">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/dynapdf_logo.png" alt="Logo" style="height: 60px; width: auto;" class="d-inline-block align-top">
                </a>
            </div>
        </nav>
    </header>

    <main class="container">
        @RenderBody()
    </main>

    
    <footer class="border-top footer text-muted bg-light">
        <div class="container d-flex justify-content-between align-items-center py-3">
            <span>&copy; 2026 - DynaPDF</span>
            <div class="version-tag">
                <span class="badge rounded-pill bg-secondary" style="opacity: 0.7;">
                    v1.4.0
                </span>
                <small class="ms-2" style="font-size: 0.75rem;">Build: 12-02-26-release</small>
            </div>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>