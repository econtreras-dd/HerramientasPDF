@{
    ViewData["Title"] = "Unir PDF";
}

<script src="/js/pdfjs/pdf.min.js"></script>
<script>
    var pdfjsLib = window['pdfjs-dist/build/pdf'];
    pdfjsLib.GlobalWorkerOptions.workerSrc = '/js/pdfjs/pdf.worker.min.js';
</script>

<div id="loader-overlay" style="display:none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(255,255,255,0.8); z-index: 10000; justify-content: center; align-items: center; flex-direction: column;">
    <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;"></div>
    <h3 class="mt-3 text-primary fw-bold">Uniendo archivos...</h3>
</div>

<div id="customPassModal" style="display:none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 11000; justify-content: center; align-items: center;">
    <div class="card shadow-lg border-0" style="max-width: 400px; width: 90%; border-top: 5px solid #ffc107 !important;">
        <div class="card-body text-center p-4">
            <i class="bi bi-shield-lock text-warning" style="font-size: 3rem;"></i>
            <h4 class="fw-bold mt-2">Archivo Protegido</h4>
            <p id="nombreArchivoProtegido" class="text-muted small text-truncate fw-bold"></p>
            <div id="errorPassword" class="alert alert-danger py-1 small" style="display:none;">Contraseña incorrecta</div>
            <div class="my-3 text-start">
                <input type="password" id="pdfPass" class="form-control" placeholder="Ingresa la contraseña">
            </div>
            <div class="d-grid gap-2">
                <button class="btn btn-primary fw-bold" id="btnDesbloquear">Desbloquear</button>
                <button type="button" class="btn btn-link btn-sm text-muted" id="btnOmitir">Omitir este archivo</button>
            </div>
        </div>
    </div>
</div>

<div class="container mt-5">
    <div class="main-content-card shadow-lg p-4 bg-white rounded">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary btn-sm">← Volver</a>
            <h2 class="fw-bold m-0 text-primary">
                Unir PDF <span id="contadorArchivos" class="badge bg-secondary fs-6">0 archivos</span>
            </h2>
        </div>

        <div class="mb-4">
            <label class="form-label fw-bold">1. Selecciona o arrastra varios archivos:</label>
            <input type="file" id="inputArchivos" class="form-control form-control-lg" multiple accept="application/pdf" />
        </div>

        <ul id="listaArchivos" class="list-group mb-4">
            <li class="list-group-item text-muted text-center py-5">No hay archivos seleccionados</li>
        </ul>

        <button type="button" id="btnCombinar" onclick="enviarFormularioUnir()" class="btn btn-primary btn-lg w-100 shadow fw-bold" disabled>
            Combinar Documentos
        </button>
    </div>
</div>

<style>
    #listaArchivos .list-group-item {
        width: 100% !important;
        cursor: move;
        transition: background 0.2s;
        user-select: none;
    }

    .dragging {
        opacity: 0.5;
        background-color: #f8f9fa !important;
        border: 2px dashed #0d6efd !important;
    }

    .drag-over {
        border-top: 4px solid #0d6efd !important;
    }

    .thumb-preview {
        width: 50px;
        height: 65px;
        background: #eee;
        border: 1px solid #ccc;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

        .thumb-preview img {
            max-width: 100%;
            max-height: 100%;
            pointer-events: none;
        }
</style>

<script>
    let archivosArray = []; // Objetos { file: File, password: "" }

    // 1. CARGA DE ARCHIVOS (Secuencial)
    document.getElementById('inputArchivos').addEventListener('change', async function(e) {
        if (!e.target.files.length) return;

        const archivosSeleccionados = Array.from(e.target.files);
        e.target.value = "";

        for (const file of archivosSeleccionados) {
            const nuevoObjeto = { file: file, password: "" };
            archivosArray.push(nuevoObjeto);
            // Añadimos y esperamos a que procese (incluyendo posible modal de clave)
            await renderizarElementoIndividual(archivosArray.length - 1);
        }
        actualizarEstadoBotonYContador();
    });

    // 2. RENDERIZADO INDIVIDUAL (Para carga inicial)
    async function renderizarElementoIndividual(index) {
        const lista = document.getElementById('listaArchivos');
        const itemObj = archivosArray[index];

        if (index === 0) lista.innerHTML = '';

        const item = crearElementoDOM(itemObj, index);
        lista.appendChild(item);

        return await generarMiniatura(index);
    }

    // 3. RENDERIZADO TOTAL (Para reordenar o eliminar)
    async function renderizarLista() {
        const lista = document.getElementById('listaArchivos');
        lista.innerHTML = '';

        if (archivosArray.length === 0) {
            lista.innerHTML = '<li class="list-group-item text-muted text-center py-5">No hay archivos seleccionados</li>';
        } else {
            // Reconstruimos la lista físicamente
            for (let i = 0; i < archivosArray.length; i++) {
                const item = crearElementoDOM(archivosArray[i], i);
                lista.appendChild(item);
                await generarMiniatura(i);
            }
        }
        actualizarEstadoBotonYContador();
    }

    // Función auxiliar para no repetir código de creación de HTML
    function crearElementoDOM(obj, index) {
        const item = document.createElement('li');
        item.className = 'list-group-item d-flex align-items-center p-2 mb-2 border rounded shadow-sm';
        item.draggable = true;
        item.dataset.index = index;

        item.innerHTML = `
            <div class="d-flex align-items-center flex-grow-1" style="min-width: 0; pointer-events: none;">
                <i class="bi bi-grip-vertical me-2 text-muted fs-4"></i>
                <div class="me-3 thumb-preview" id="thumb-${index}" style="width:50px; height:65px; background:#eee; display:flex; align-items:center; justify-content:center; overflow:hidden; border:1px solid #ccc;">
                    <div class="spinner-border spinner-border-sm text-secondary"></div>
                </div>
                <div class="text-truncate">
                    <span class="d-block fw-bold text-truncate small">${obj.file.name}</span>
                    <small class="text-muted">${(obj.file.size / 1024).toFixed(1)} KB</small>
                </div>
            </div>
            <div class="ms-auto" style="pointer-events: auto;">
                <button type="button" class="btn btn-sm text-danger" onclick="eliminar(${index})">×</button>
            </div>`;

        // Eventos Drag & Drop
        item.addEventListener('dragstart', (e) => { e.dataTransfer.setData('text/plain', index); item.classList.add('dragging'); });
        item.addEventListener('dragover', (e) => { e.preventDefault(); item.classList.add('drag-over'); });
        item.addEventListener('dragleave', () => item.classList.remove('drag-over'));
        item.addEventListener('drop', (e) => {
            e.preventDefault();
            const from = e.dataTransfer.getData('text/plain');
            reordenar(parseInt(from), index);
        });
        item.addEventListener('dragend', () => item.classList.remove('dragging'));

        return item;
    }

    // 4. MINIATURAS Y CONTRASEÑAS
    async function generarMiniatura(index) {
        const itemObj = archivosArray[index];
        const container = document.getElementById(`thumb-${index}`);
        if (!container) return;

        return new Promise((resolve) => {
            const reader = new FileReader();
            reader.onload = async function() {
                const typedarray = new Uint8Array(this.result);
                const loadingTask = pdfjsLib.getDocument({
                    data: typedarray,
                    password: itemObj.password
                });

                loadingTask.onPassword = (updatePassword, reason) => {
                    mostrarModalClave(itemObj.file.name, (pass) => {
                        itemObj.password = pass;
                        updatePassword(pass);
                    }, reason === 2, index);
                };

                try {
                    const pdf = await loadingTask.promise;
                    const page = await pdf.getPage(1);
                    const viewport = page.getViewport({ scale: 0.15 });
                    const canvas = document.createElement('canvas');
                    canvas.height = viewport.height;
                    canvas.width = viewport.width;
                    await page.render({ canvasContext: canvas.getContext('2d'), viewport: viewport }).promise;

                    container.innerHTML = `<img src="${canvas.toDataURL()}" style="max-width:100%; max-height:100%;" />`;
                    resolve();
                } catch (e) {
                    container.innerHTML = '<i class="bi bi-file-earmark-lock text-danger"></i>';
                    resolve();
                }
            };
            reader.readAsArrayBuffer(itemObj.file);
        });
    }

    function mostrarModalClave(nombre, callback, esError, index) {
        const modal = document.getElementById('customPassModal');
        document.getElementById('nombreArchivoProtegido').innerText = nombre;
        document.getElementById('errorPassword').style.display = esError ? 'block' : 'none';
        document.getElementById('pdfPass').value = "";
        modal.style.display = 'flex';

        document.getElementById('btnDesbloquear').onclick = () => {
            const p = document.getElementById('pdfPass').value;
            if(p) { modal.style.display = 'none'; callback(p); }
        };

        document.getElementById('btnOmitir').onclick = () => {
            modal.style.display = 'none';
            eliminar(index);
        };
    }

    function reordenar(from, to) {
        const item = archivosArray.splice(from, 1)[0];
        archivosArray.splice(to, 0, item);
        renderizarLista(); // Reconstruye con los nuevos índices
    }

    function eliminar(index) {
        archivosArray.splice(index, 1);
        renderizarLista();
    }

    function actualizarEstadoBotonYContador() {
        const btn = document.getElementById('btnCombinar');
        const contador = document.getElementById('contadorArchivos');
        if(btn) btn.disabled = archivosArray.length < 2;
        if(contador) contador.innerText = `${archivosArray.length} archivos`;
    }

    async function enviarFormularioUnir() {
        const overlay = document.getElementById('loader-overlay');
        overlay.style.display = 'flex';

        const data = new FormData();
        archivosArray.forEach(item => {
            data.append('archivos', item.file);
            data.append('passwords', item.password || "");
        });

        try {
            const response = await fetch('@Url.Action("Procesar", "Unir")', { method: 'POST', body: data });
            if (response.ok) {
                const blob = await response.blob();
                const a = document.createElement('a');
                a.href = window.URL.createObjectURL(blob);
                a.download = "Expediente_Unido.pdf";
                a.click();
                location.reload();
            } else {
                alert("Error al procesar. Verifica las claves.");
                overlay.style.display = 'none';
            }
        } catch (error) {
            alert("Error de red.");
            overlay.style.display = 'none';
        }
    }
</script>